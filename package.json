{
  "name": "quranclass",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:web": "npm run build",
    "preview": "vite preview",
    "seed:quran": "tsx scripts/seed.ts",
    "cap:sync": "npm run build:web && npx cap sync",
