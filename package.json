    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.3.1",
    "i18next": "^24.2.2",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^2.15.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.2",
